includes:
    - vendor/phpstan/phpstan-phpunit/extension.neon
    - vendor/szepeviktor/phpstan-wordpress/extension.neon

parameters:
    level: 6
    paths:
        - src/
    excludePaths:
        - */tests/*
        - src/*/vendor/*
        - src/Component/*/templates/*
    scanDirectories:
        - vendor/roots/wordpress-no-content/wp-includes/
    ignoreErrors:
        -
            identifier: trait.unused
            reportUnmatched: false
        -
            identifier: class.notFound
            path: src/Component/Scheduler/Bridge/EventBridge/src/Interceptor/ActionSchedulerInterceptor.php
        -
            identifier: class.notFound
            path: src/Component/Scheduler/Bridge/EventBridge/src/Collector/ActionSchedulerCollector.php
