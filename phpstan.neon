includes:
    - vendor/phpstan/phpstan-phpunit/extension.neon
    - vendor/szepeviktor/phpstan-wordpress/extension.neon

parameters:
    level: 6
    paths:
        - src/
    excludePaths:
        - */tests/*
        - src/*/vendor/*
        - src/Component/*/templates/*
    scanDirectories:
        - web/wp/wp-includes/
        - web/wp-content/plugins/action-scheduler/
    scanFiles:
        - vendor/wp-cli/wp-cli/php/utils.php
    ignoreErrors:
        -
            identifier: trait.unused
            reportUnmatched: false
        -
            identifier: function.resultUnused
            path: src/Component/Scheduler/Bridge/EventBridge/src/Interceptor/*
            reportUnmatched: false
