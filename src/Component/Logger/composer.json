{
    "name": "wppack/logger",
    "description": "PSR-3 logging for WordPress",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "psr/log": "^3.0"
    },
    "suggest": {
        "monolog/monolog": "For advanced logging features (handlers, formatters, processors)",
        "wppack/dependency-injection": "For DI container integration with channel-based injection"
    },
    "autoload": {
        "psr-4": {
            "WpPack\\Component\\Logger\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WpPack\\Component\\Logger\\Tests\\": "tests/"
        }
    }
}
