{
  "name": "wppack/eventbridge-scheduler",
  "description": "Amazon EventBridge Scheduler backend for WPPack Scheduler",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "async-aws/scheduler": "^1.0",
    "wordpress/core-implementation": "^6.3",
    "wppack/messenger": "^1.0",
    "wppack/scheduler": "^1.0",
    "wppack/serializer": "^1.0",
    "wppack/site": "^1.0"
  },
  "require-dev": {
    "woocommerce/action-scheduler": "^3.7"
  },
  "autoload": {
    "psr-4": {
