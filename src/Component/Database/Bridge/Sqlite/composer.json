{
  "name": "wppack/sqlite-database",
  "description": "SQLite database driver for WPPack",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "ext-pdo_sqlite": "*",
    "phpmyadmin/sql-parser": "^6.0",
    "symfony/polyfill-php84": "^1.34",
    "wppack/database": "^1.0",
    "wppack/dsn": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "WPPack\\Component\\Database\\Bridge\\Sqlite\\": "src/"
    }
  },
  "autoload-dev": {
