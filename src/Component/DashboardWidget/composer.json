{
  "name": "wppack/dashboard-widget",
  "description": "Dashboard widget for WordPress",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "wordpress/core-implementation": "^6.3",
    "wppack/http-foundation": "^1.0",
    "wppack/role": "^1.0"
  },
  "suggest": {
    "wppack/security": "Required for #[CurrentUser] injection in __invoke()",
    "wppack/templating": "For template rendering via render()"
  },
  "autoload": {
    "psr-4": {
      "WPPack\\Component\\DashboardWidget\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "WPPack\\Component\\DashboardWidget\\Tests\\": "tests/"
    }
  }
}
