{
    "name": "wppack/messenger",
    "description": "Transport-agnostic messaging bus for WordPress",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "psr/log": "^3.0",
        "wppack/serializer": "^1.0",
        "wppack/site": "^1.0"
    },
    "suggest": {
        "wppack/sqs-messenger": "SQS transport for async messaging via AWS Lambda"
    },
    "autoload": {
        "psr-4": {
            "WPPack\\Component\\Messenger\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WPPack\\Component\\Messenger\\Tests\\": "tests/"
        }
    }
}
