{
    "name": "wppack/http-client",
    "description": "PSR-18 HTTP client wrapping WordPress HTTP API",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "psr/http-client": "^1.0",
        "psr/http-message": "^2.0",
        "psr/http-factory": "^1.0"
    },
    "require-dev": {
        "wppack/hook": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "WpPack\\Component\\HttpClient\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WpPack\\Component\\HttpClient\\Tests\\": "tests/"
        }
    }
}
