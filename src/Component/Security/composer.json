{
  "name": "wppack/security",
  "description": "Authentication and authorization framework for WordPress",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "wordpress/core-implementation": "^6.7",
    "wppack/event-dispatcher": "^1.0",
    "wppack/http-foundation": "^1.0",
    "wppack/role": "^1.0",
    "wppack/site": "^1.0"
  },
  "require-dev": {
    "wppack/dependency-injection": "^1.0"
  },
  "suggest": {
    "wppack/dependency-injection": "For DI container integration with automatic authenticator and voter registration"
  },
  "autoload": {
    "psr-4": {
      "WPPack\\Component\\Security\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "WPPack\\Component\\Security\\Tests\\": "tests/"
    }
  }
}
