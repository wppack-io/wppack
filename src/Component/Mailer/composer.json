{
  "name": "wppack/mailer",
  "description": "Email abstraction with TransportInterface for WordPress",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "wordpress/core-implementation": "^6.7",
    "wppack/dsn": "^1.0",
    "wppack/mime": "^1.0"
  },
  "suggest": {
    "wppack/amazon-mailer": "Amazon SES transport (ses:// DSN, API or SMTP)",
    "wppack/azure-mailer": "Azure Communication Services transport (azure:// DSN)",
    "wppack/sendgrid-mailer": "SendGrid transport (sendgrid:// DSN)"
  },
  "autoload": {
    "psr-4": {
      "WPPack\\Component\\Mailer\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "WPPack\\Component\\Mailer\\Tests\\": "tests/"
    }
  }
}
