{
    "name": "wppack/admin",
    "description": "Administration utilities for WordPress",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "wppack/http-foundation": "^1.0",
        "wppack/role": "^1.0"
    },
    "suggest": {
        "wppack/security": "Required for #[CurrentUser] injection in __invoke()"
    },
    "autoload": {
        "psr-4": {
            "WpPack\\Component\\Admin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WpPack\\Component\\Admin\\Tests\\": "tests/"
        }
    }
}
