{
    "name": "wppack/s3-storage-plugin",
    "description": "WordPress plugin for S3-based media storage",
    "type": "wordpress-plugin",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "wppack/dependency-injection": "^1.0",
        "wppack/hook": "^1.0",
        "wppack/http-foundation": "^1.0",
        "wppack/kernel": "^1.0",
        "wppack/media": "^1.0",
        "wppack/messenger": "^1.0",
        "wppack/mime": "^1.0",
        "wppack/rest": "^1.0",
        "wppack/role": "^1.0",
        "wppack/s3-storage": "^1.0",
        "wppack/site": "^1.0",
        "wppack/storage": "^1.0",
        "async-aws/s3": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "WpPack\\Plugin\\S3StoragePlugin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WpPack\\Plugin\\S3StoragePlugin\\Tests\\": "tests/"
        }
    }
}
