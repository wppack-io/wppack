{
  "name": "wppack/passkey-login-plugin",
  "description": "WebAuthn/Passkey passwordless login for WordPress",
  "type": "wordpress-plugin",
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "wppack/dependency-injection": "^1.0",
    "wppack/hook": "^1.0",
    "wppack/kernel": "^1.0",
    "wppack/passkey-security": "^1.0"
  },
  "suggest": {
    "wppack/security": "Required for authentication framework"
  },
  "autoload": {
    "psr-4": {
      "WPPack\\Plugin\\PasskeyLoginPlugin\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "WPPack\\Plugin\\PasskeyLoginPlugin\\Tests\\": "tests/"
    }
  },
  "extra": {
    "installer-name": "wppack-passkey-login"
  }
}
