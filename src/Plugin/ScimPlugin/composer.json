{
    "name": "wppack/scim-plugin",
    "description": "WordPress plugin for SCIM 2.0 user provisioning",
    "type": "wordpress-plugin",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "wppack/dependency-injection": "^1.0",
        "wppack/event-dispatcher": "^1.0",
        "wppack/http-foundation": "^1.0",
        "wppack/kernel": "^1.0",
        "wppack/rest": "^1.0",
        "wppack/scim": "^1.0",
        "wppack/security": "^1.0",
        "wppack/site": "^1.0",
        "wppack/user": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "WPPack\\Plugin\\ScimPlugin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WPPack\\Plugin\\ScimPlugin\\Tests\\": "tests/"
        }
    },
    "extra": {
        "installer-name": "wppack-scim"
    }
}
