{
    "name": "wppack/wppack",
    "description": "Modern WordPress Component Library",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "async-aws/ses": "^1.14"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.68",
        "php-stubs/wordpress-stubs": "^6.9",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "WpPack\\Component\\Hook\\": "src/Component/Hook/",
            "WpPack\\Component\\DependencyInjection\\": "src/Component/DependencyInjection/",
            "WpPack\\Component\\Config\\": "src/Component/Config/",
            "WpPack\\Component\\EventDispatcher\\": "src/Component/EventDispatcher/",
            "WpPack\\Component\\Filesystem\\": "src/Component/Filesystem/",
            "WpPack\\Component\\Kernel\\": "src/Component/Kernel/",
            "WpPack\\Component\\Mailer\\": "src/Component/Mailer/",
            "WpPack\\Component\\Messenger\\": "src/Component/Messenger/",
            "WpPack\\Component\\Scheduler\\": "src/Component/Scheduler/",
            "WpPack\\Component\\Media\\": "src/Component/Media/",
            "WpPack\\Component\\Admin\\": "src/Component/Admin/",
            "WpPack\\Component\\Rest\\": "src/Component/Rest/",
            "WpPack\\Component\\PostType\\": "src/Component/PostType/",
            "WpPack\\Component\\Query\\": "src/Component/Query/",
            "WpPack\\Component\\Command\\": "src/Component/Command/",
            "WpPack\\Component\\Cache\\": "src/Component/Cache/",
            "WpPack\\Component\\Database\\": "src/Component/Database/",
            "WpPack\\Component\\Security\\": "src/Component/Security/",
            "WpPack\\Component\\Sanitizer\\": "src/Component/Sanitizer/",
            "WpPack\\Component\\Validator\\": "src/Component/Validator/",
            "WpPack\\Component\\HttpClient\\": "src/Component/HttpClient/",
            "WpPack\\Component\\HttpFoundation\\": "src/Component/HttpFoundation/",
            "WpPack\\Component\\Plugin\\": "src/Component/Plugin/",
            "WpPack\\Component\\Theme\\": "src/Component/Theme/",
            "WpPack\\Component\\Widget\\": "src/Component/Widget/",
            "WpPack\\Component\\Setting\\": "src/Component/Setting/",
            "WpPack\\Component\\User\\": "src/Component/User/",
            "WpPack\\Component\\Block\\": "src/Component/Block/",
            "WpPack\\Component\\Comment\\": "src/Component/Comment/",
            "WpPack\\Component\\Taxonomy\\": "src/Component/Taxonomy/",
            "WpPack\\Component\\Role\\": "src/Component/Role/",
            "WpPack\\Component\\Templating\\": "src/Component/Templating/",
            "WpPack\\Component\\Logger\\": "src/Component/Logger/",
            "WpPack\\Component\\Option\\": "src/Component/Option/",
            "WpPack\\Component\\Transient\\": "src/Component/Transient/",
            "WpPack\\Component\\Nonce\\": "src/Component/Nonce/",
            "WpPack\\Component\\Shortcode\\": "src/Component/Shortcode/",
            "WpPack\\Component\\Routing\\": "src/Component/Routing/",
            "WpPack\\Component\\Ajax\\": "src/Component/Ajax/",
            "WpPack\\Component\\Debug\\": "src/Component/Debug/",
            "WpPack\\Component\\NavigationMenu\\": "src/Component/NavigationMenu/",
            "WpPack\\Component\\Feed\\": "src/Component/Feed/",
            "WpPack\\Component\\OEmbed\\": "src/Component/OEmbed/",
            "WpPack\\Component\\SiteHealth\\": "src/Component/SiteHealth/",
            "WpPack\\Component\\DashboardWidget\\": "src/Component/DashboardWidget/",
            "WpPack\\Component\\Translation\\": "src/Component/Translation/",
            "WpPack\\Plugin\\SchedulerPlugin\\": "src/Plugin/SchedulerPlugin/",
            "WpPack\\Plugin\\S3StoragePlugin\\": "src/Plugin/S3StoragePlugin/",
            "WpPack\\Component\\Mailer\\Bridge\\Amazon\\": "src/Component/Mailer/Bridge/Amazon/",
            "WpPack\\Plugin\\AmazonMailerPlugin\\": "src/Plugin/AmazonMailerPlugin/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WpPack\\Tests\\": "tests/"
        }
    },
    "replace": {
        "wppack/hook": "self.version",
        "wppack/dependency-injection": "self.version",
        "wppack/config": "self.version",
        "wppack/event-dispatcher": "self.version",
        "wppack/filesystem": "self.version",
        "wppack/kernel": "self.version",
        "wppack/mailer": "self.version",
        "wppack/messenger": "self.version",
        "wppack/scheduler": "self.version",
        "wppack/media": "self.version",
        "wppack/admin": "self.version",
        "wppack/rest": "self.version",
        "wppack/post-type": "self.version",
        "wppack/query": "self.version",
        "wppack/command": "self.version",
        "wppack/cache": "self.version",
        "wppack/database": "self.version",
        "wppack/security": "self.version",
        "wppack/sanitizer": "self.version",
        "wppack/validator": "self.version",
        "wppack/http-client": "self.version",
        "wppack/http-foundation": "self.version",
        "wppack/plugin": "self.version",
        "wppack/theme": "self.version",
        "wppack/widget": "self.version",
        "wppack/setting": "self.version",
        "wppack/user": "self.version",
        "wppack/block": "self.version",
        "wppack/comment": "self.version",
        "wppack/taxonomy": "self.version",
        "wppack/role": "self.version",
        "wppack/templating": "self.version",
        "wppack/logger": "self.version",
        "wppack/option": "self.version",
        "wppack/transient": "self.version",
        "wppack/nonce": "self.version",
        "wppack/shortcode": "self.version",
        "wppack/routing": "self.version",
        "wppack/ajax": "self.version",
        "wppack/debug": "self.version",
        "wppack/navigation-menu": "self.version",
        "wppack/feed": "self.version",
        "wppack/oembed": "self.version",
        "wppack/site-health": "self.version",
        "wppack/dashboard-widget": "self.version",
        "wppack/translation": "self.version",
        "wppack/scheduler-plugin": "self.version",
        "wppack/s3-storage-plugin": "self.version",
        "wppack/amazon-mailer": "self.version",
        "wppack/amazon-mailer-plugin": "self.version"
    },
    "scripts": {
        "phpstan": "phpstan analyse",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix",
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
